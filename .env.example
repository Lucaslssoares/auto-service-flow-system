# ========================================
# CONFIGURAÇÃO DE AMBIENTE — EXEMPLO
# ========================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha com suas credenciais do seu projeto Supabase
# 3. NUNCA commite o arquivo .env (já está no .gitignore)
#
# Onde encontrar as credenciais:
#   https://supabase.com/dashboard → seu projeto → Settings → API
#
# ========================================

# URL do projeto Supabase
# Formato: https://[id-do-projeto].supabase.co
VITE_SUPABASE_URL=https://SEU_PROJETO_ID.supabase.co

# Chave pública (anon key) — segura para uso no frontend
# Encontre em: Settings > API > "anon public"
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SUA_CHAVE_AQUI

# ID do projeto (para referência)
VITE_SUPABASE_PROJECT_ID=SEU_PROJETO_ID

# ========================================
# IMPORTANTE
# ========================================
# - A anon key é protegida por Row Level Security (RLS)
# - A service_role key NUNCA deve ser usada no frontend
# - Em produção, configure as variáveis no painel do seu hosting
# ========================================
